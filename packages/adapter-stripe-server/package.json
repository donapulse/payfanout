{
  "name": "@payfanout/adapter-stripe-server",
  "version": "0.1.0",
  "description": "Server-side Stripe adapter for PayFanout (PaymentIntents, Refunds, webhook signature verification). Holds secrets — never bundle client-side.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "dependencies": {
    "@payfanout/core": "workspace:*",
    "stripe": "^16.0.0"
  },
  "devDependencies": {
    "@payfanout/conformance": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
