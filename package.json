{
  "name": "payfanout",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run packages/integration-tests",
    "e2e": "pnpm --filter @payfanout/e2e e2e",
    "typecheck": "tsc -p tsconfig.json",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "audit:deps": "node scripts/audit-deps.mjs",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run check:boundaries && pnpm run test",
    "changeset": "changeset",
    "build": "pnpm -r run build",
    "release": "pnpm run check && pnpm run build && changeset publish",
    "docs:api": "typedoc",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint . --max-warnings 0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "vitest@<3.2.6": ">=3.2.6",
      "vite@<6.4.3": ">=6.4.3",
      "esbuild@<0.25.0": ">=0.25.0"
    }
  }
}
