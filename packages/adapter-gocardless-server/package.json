{
  "name": "@payfanout/adapter-gocardless-server",
  "version": "1.0.2",
  "license": "MIT",
  "description": "Server-side GoCardless adapter for PayFanout (Billing Requests REST API: hosted bank authorisation flows, payments, refunds, events, webhooks). Holds secrets — never bundle client-side.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "dependencies": {
    "@payfanout/core": "workspace:*"
  },
  "devDependencies": {
    "@payfanout/conformance": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
